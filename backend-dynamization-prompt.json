  "djangoAdminStructure": {
    "description": "Django admin organized with separate sections per page",
    "sections": [
      { "name": "Global Settings", "app": "core", "models": ["SiteConfig", "ThemeColor", "ButtonStyle", "Logo", "SocialLink"], "icon": "settings" },
      { "name": "Navigation", "app": "navigation", "models": ["MainNavItem", "MegaMenuItem", "FooterSection", "FooterLink"], "icon": "menu" },
      { "name": "Home Page", "app": "home", "models": ["HeroSection", "HeroCTA", "ProcessSection", "ProcessStep", "TestimonialSection", "Testimonial", "AboutSection", "FeatureSection", "FeatureCard", "GallerySection", "GalleryFeature", "LaunchPhase", "LaunchPhaseCard"], "icon": "home" },
      { "name": "Pricing Page", "app": "pricing", "models": ["PricingPageConfig", "PricingPlan", "PlanFeature", "PricingPromotion", "PricingFAQ"], "icon": "attach_money" },
      { "name": "FAQ Page", "app": "faq", "models": ["FAQPageConfig", "FAQCategory", "FAQQuestion"], "icon": "help" },
      { "name": "Careers Page", "app": "careers", "models": ["CareersPageConfig", "JobCategory", "JobPosition"], "icon": "work" },
      { "name": "Team Page", "app": "team", "models": ["TeamPageConfig", "CompanyValue", "TeamMember"], "icon": "groups" },
      { "name": "Contact Page", "app": "contact", "models": ["ContactPageConfig", "ContactCategory", "OfficeLocation"], "icon": "contact_mail" },
      { "name": "Help Center", "app": "help", "models": ["HelpPageConfig", "HelpLinkColumn", "HelpLink"], "icon": "support" },
      { "name": "Blog", "app": "blog", "models": ["BlogPost", "BlogCategory", "BlogAuthor"], "icon": "article" },
      { "name": "Features Pages", "app": "features", "models": ["FeaturePageConfig", "FeaturePage", "FeaturePageSection"], "icon": "star" },
      { "name": "Legal Pages", "app": "legal", "models": ["LegalPage"], "icon": "gavel" },
      { "name": "SEO", "app": "seo", "models": ["GlobalSEO", "PageSEO"], "icon": "search" }
    ]
  },

  "seoConfiguration": {
    "globalSEO": {
      "fields": {
