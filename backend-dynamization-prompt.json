    "pageSEO": {
      "description": "Every page needs these SEO fields",
      "fields": {
        "metaTitle": "string (50-60 chars)",
        "metaDescription": "string (150-160 chars)",
        "metaKeywords": "text",
        "canonicalUrl": "url (optional override)",
        "robots": "choice",
        "ogTitle": "string",
